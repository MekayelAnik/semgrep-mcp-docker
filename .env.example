# Copy to `.env` next to docker-compose.yml — compose auto-loads it.
# All vars are OPTIONAL. Defaults in parentheses.

# --- Code directory (what semgrep scans) ---
CODE_DIR=./code                 # Host path (default: ./code) — mounts read-only at /code

# --- Custom rules directory ---
CUSTOM_RULES_DIR=./custom-rules # Host path to YAML rule files (default: ./custom-rules)

# --- Optional: your own TLS certs (skip to auto-gen self-signed) ---
# CERTS_DIR=./certs

# --- Semgrep Pro Engine (9 tools vs 6 in OSS mode) ---
# SEMGREP_APP_TOKEN=sgp_xxxxxxxxxxxxxxxxxxxxxxxxx
# REQUIRE_PRO=false             # "true" to fail-fast when token missing

# --- HAProxy Bearer-token auth ---
# SEMGREP_MCP_API_KEY=your-long-random-token

# --- CORS (permissive or allowlist) ---
# CORS=*
# CORS=https://app.example.com,https://dev.example.com
