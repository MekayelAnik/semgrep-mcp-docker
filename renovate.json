{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":configMigration"
  ],
  "enabledManagers": [
    "github-actions",
    "custom.regex"
  ],
  "pinDigests": false,
  "github-actions": {
    "managerFilePatterns": [
      "/(^|/).github/workflows/[^/]+\\.ya?ml$/",
      "/(^|/).github/actions/[^/]+/action\\.ya?ml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track crane (go-containerregistry) pinned fallback versions",
      "managerFilePatterns": ["/.github/actions/setup-build-env/action\\.yml$/"],
      "matchStrings": ["CRANE_FALLBACK_VERSIONS=\\(\"(?<currentValue>v[\\d.]+)\""],
      "depNameTemplate": "google/go-containerregistry",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Track semgrep PyPI version pinned in build_data/version",
      "managerFilePatterns": ["/^build_data/version$/"],
      "matchStrings": ["^(?<currentValue>[\\d.]+)\\s*$"],
      "depNameTemplate": "semgrep",
      "datasourceTemplate": "pypi"
    },
    {
      "customType": "regex",
      "description": "Track base Python image pinned in build_data/base-image",
      "managerFilePatterns": ["/^build_data/base-image$/"],
      "matchStrings": ["^(?<depName>[^:\\s]+):(?<currentValue>[^\\s]+)\\s*$"],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Track HAProxy image pinned in build_data/haproxy-image",
      "managerFilePatterns": ["/^build_data/haproxy-image$/"],
      "matchStrings": ["^(?<depName>[^:\\s]+):(?<currentValue>[^\\s]+)\\s*$"],
      "datasourceTemplate": "docker"
    }
  ],
  "labels": [
    "dependencies",
    "automated"
  ],
  "assignees": [
    "mekayelanik"
  ],
  "reviewers": [
    "mekayelanik"
  ],
  "timezone": "Asia/Dhaka",
  "schedule": [
    "before 6am on monday"
  ],
  "automerge": true,
  "platformAutomerge": false,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "rebaseWhen": "behind-base-branch",
  "prConcurrentLimit": 10,
  "prHourlyLimit": 5,
  "minimumReleaseAge": "0 days",
  "internalChecksFilter": "strict",
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security"
    ],
    "minimumReleaseAge": null
  },
  "packageRules": [
    {
      "description": "Disable pin and digest updates globally",
      "matchUpdateTypes": [
        "pin",
        "digest"
      ],
      "enabled": false
    },
    {
      "description": "GitHub Actions: major versions only; disable minor/patch",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "enabled": false
    },
    {
      "description": "setup-crane: allow minor updates (no major tag available)",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["imjasonh/setup-crane"],
      "matchUpdateTypes": ["minor"],
      "enabled": true,
      "automerge": true
    },
    {
      "description": "GitHub Actions: major updates as PRs",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "labels": [
        "dependencies",
        "github-actions"
      ],
      "groupName": "github-actions-major"
    },
    {
      "description": "Semgrep PyPI: auto-merge all updates, build-data commit",
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["semgrep"],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "labels": ["dependencies", "semgrep-version"],
      "commitMessagePrefix": "build: ",
      "commitMessageTopic": "semgrep",
      "groupName": "semgrep-version"
    },
    {
      "description": "Base Python image: auto-merge minor/patch",
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["python"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "labels": ["dependencies", "base-image"],
      "commitMessagePrefix": "build: ",
      "groupName": "base-image"
    },
    {
      "description": "HAProxy image: auto-merge minor/patch",
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["haproxy"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "labels": ["dependencies", "haproxy-image"],
      "commitMessagePrefix": "build: ",
      "groupName": "haproxy-image"
    }
  ],
  "commitMessagePrefix": "ci: ",
  "commitMessageAction": "update",
  "commitMessageTopic": "{{depName}}",
  "gitIgnoredAuthors": [
    "renovate[bot]@users.noreply.github.com"
  ]
}
